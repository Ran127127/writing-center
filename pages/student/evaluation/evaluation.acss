/* pages/student/evaluation/evaluation.acss */
.submitted-card { text-align:center; padding:60rpx 0; }
.submitted-icon { font-size:80rpx; margin-bottom:20rpx; }
.submitted-text { font-size:32rpx; font-weight:600; color:#09b56d; }
.eval-course    { font-size:28rpx; color:#555; }
.q-title        { font-size:28rpx; color:#333; margin:24rpx 0 16rpx; font-weight:500; }
.required       { color:#ff4d4f; margin-left:4rpx; }
.radio-group    { display:flex; flex-wrap:wrap; gap:16rpx; margin-bottom:8rpx; }
.radio-item {
  padding:12rpx 28rpx; border-radius:100rpx;
  border:2rpx solid #ddd; font-size:26rpx; color:#555;
}
.radio-selected { border-color:#1677ff; background:#e6f0ff; color:#1677ff; }
.score-row      { display:flex; align-items:center; gap:16rpx; margin-top:8rpx; }
.score-slider   { flex:1; }
.score-value    { font-size:32rpx; font-weight:700; color:#1677ff; width:100rpx; text-align:right; }
